---
import PageLayout from '../layouts/PageLayout.astro';
import EntryRow from '../components/EntryRow.astro';
import { siteConfig } from '../data/config';
import { resumeIdentity } from '../data/resume';
---

<PageLayout title="Home" description={resumeIdentity.defaultDescription}>
  <section class="hero">
    <p class="hero-name">{resumeIdentity.name}</p>
    <p class="hero-label mono">{resumeIdentity.title}</p>
    <h1 class="hero-h1">End to end is where I thrive.</h1>
    <p class="hero-sub">
      At <a href="https://www.rebuyengine.com" target="_blank" rel="noopener noreferrer">Rebuy</a> I am
      part of the founding team on <a
        href="https://rebuy.app"
        target="_blank"
        rel="noopener noreferrer">rebuy.app</a
      >, building the commerce platform from a blank file. I've shipped the merchant dashboard,
      customer checkout, and Payouts. When the team needed better tooling I wrote the CLI and code
      generator to get us there. My best work happens when I can follow a problem all the way
      through — from the product conversation to the deployment.
    </p>
    <div class="hero-ctas">
      <button data-contact-trigger class="btn-primary">Get in touch</button>
      <a href="projects" class="btn-secondary">Projects</a>
      <a href="/projects?view=resume" class="btn-secondary">Resume</a>
    </div>
    <p class="hero-meta mono">
      Remote · Salt Lake City, UT · TypeScript · React · Node.js · Kubernetes
    </p>
  </section>

  <section class="section" aria-labelledby="about-heading">
    <h2 id="about-heading" class="section-label mono">About</h2>
    <div class="about-text">
      <p>
        The problem matters more to me than the stack. I care about building things that solve real
        world problems for people and organizations.
      </p>
      <p>
        At Rebuy I helped start <a
          href="https://rebuy.app"
          target="_blank"
          rel="noopener noreferrer">rebuy.app</a
        > from scratch — a full commerce platform built inside Rebuy. I took primary ownership of the
        merchant dashboard and customer checkout, built out Payouts alongside the team, and wrote the
        developer tooling that now powers most of our daily workflow: a CLI, an API code generator, and
        a Shopify-embeddable build system.
      </p>
      <p>
        Before Rebuy I was on the FinTech team at Pluralsight, building financial tooling around a
        B2B provisioning pipeline that processed ~$9M/month at peak. Before that, water and
        wastewater management UIs using Ignition SCADA.
      </p>
      <p>
        I came to software the long way — through video editing, self-taught over years of side
        projects, picking up whatever I needed to ship the thing I was working on. It left me with a
        strong instinct for the person on the other side of the screen.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="entry-grid">
      <EntryRow label="Currently"
        >Senior Software Engineer at Rebuy. Part of the founding team on <a
          href="https://rebuy.app"
          target="_blank"
          rel="noopener noreferrer">rebuy.app</a
        > — a greenfield commerce platform I've helped build from scratch. Since joining the R.AI team
        I've been working in distributed agentic systems: multi-agent orchestration, tool use, and the
        infrastructure underneath.</EntryRow
      >

      {
        siteConfig.activelyLooking && (
          <EntryRow label="Looking for">A role with real ownership and hard problems. </EntryRow>
        )
      }

      <EntryRow label="Stack"
        >TypeScript · React · Next.js · Node.js · PostgreSQL · Kubernetes · GCP</EntryRow
      >

      <EntryRow label="Side"
        >Running Halvor — a self-hosted homelab with extensive automation workflows and buildouts,
        running on Proxmox, OPNsense, and containerized services. Writing about it at <a href="/til"
          >/til</a
        >.
      </EntryRow>
    </div>
  </section>
</PageLayout>

<style>
  .hero {
    padding: var(--space-16) 0 var(--space-12);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }
  @media (min-width: 900px) {
    .hero {
      grid-template-columns: 1fr auto;
      align-items: start;
    }
    .hero-label,
    .hero-h1,
    .hero-sub,
    .hero-ctas,
    .hero-meta {
      grid-column: 1;
    }
  }
  .hero-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: 0.01em;
  }
  .hero-label {
    color: var(--color-accent);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .hero-h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.1;
  }
  .hero-sub {
    font-size: 1.05rem;
    color: var(--color-muted);
    line-height: 1.7;
    max-width: 64ch;
  }
  .hero-ctas {
    display: flex;
    gap: var(--space-4);
    align-items: center;
    flex-wrap: wrap;
  }
  .btn-primary {
    background: var(--color-accent);
    color: var(--color-bg);
    border: none;
    border-radius: var(--radius-sm);
    padding: var(--space-3) var(--space-6);
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 150ms ease;
    letter-spacing: 0.02em;
  }
  .btn-primary:hover {
    opacity: 0.85;
  }
  .btn-secondary {
    font-size: 0.9rem;
    color: var(--color-text);
    text-decoration: none;
    border-bottom: 1px solid var(--color-mono);
    padding-bottom: 2px;
    transition: border-color 150ms ease;
  }
  .btn-secondary:hover {
    border-color: var(--color-accent);
    text-decoration: none;
  }
  .hero-meta {
    font-size: 0.75rem;
    color: var(--color-mono);
    letter-spacing: 0.06em;
  }

  .section {
    padding: var(--space-12) 0;
    border-top: 1px solid var(--color-surface);
  }
  .section-label {
    font-size: 0.7rem;
    color: var(--color-muted);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: var(--space-8);
    font-weight: 400;
  }

  .about-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: var(--prose-width);
  }
  .about-text p {
    line-height: 1.75;
    color: var(--color-muted);
  }

  .entry-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    max-width: var(--prose-width);
  }
  .inline-trigger {
    background: none;
    border: none;
    color: var(--color-accent);
    font: inherit;
    font-size: inherit;
    padding: 0;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .inline-trigger:hover {
    opacity: 0.8;
  }
</style>
