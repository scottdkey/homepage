---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/PageHero.astro';
import TilBranch from '../../components/TilBranch.astro';
import type { TilNode } from '../../components/TilBranch.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('til', ({ data }) => !data.draft);

// Build a recursive tree from file paths
const tree: Record<string, TilNode> = {};

for (const entry of entries) {
  const parts = entry.id.split('/');
  const topCat = parts[0];
  const subPath = parts.slice(1, -1);

  if (!tree[topCat]) tree[topCat] = { entries: [], children: {} };

  let node = tree[topCat];
  for (const seg of subPath) {
    if (!node.children[seg]) node.children[seg] = { entries: [], children: {} };
    node = node.children[seg];
  }
  node.entries.push(entry);
}

const sortedTree = Object.entries(tree).sort(([a], [b]) => a.localeCompare(b));

// Search index — serialized at build time, consumed by client JS
const searchIndex = entries.map((e) => ({
  id: e.id,
  title: e.data.title,
  tags: e.data.tags,
  desc: e.data.description ?? '',
  date: e.data.pubDate.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  }),
  // category path for display: "docker / host-setup"
  path: e.id.split('/').slice(0, -1).join(' / '),
}));
---

<PageLayout title="TIL">
  <div class="page-wrap">
    <PageHero title="Today I Learned" />

    <div class="search-wrap">
      <input
        id="til-search"
        class="search-input"
        type="search"
        placeholder="Search topics, tags…"
        autocomplete="off"
        spellcheck="false"
      />
    </div>

    {entries.length === 0 && <p style="color: var(--color-muted)">No entries yet.</p>}

    <div id="til-tree" class="til-tree">
      {
        sortedTree.map(([cat, node]) => (
          <div class="til-branch">
            <p class="til-cat">{cat}</p>
            <TilBranch node={node} />
          </div>
        ))
      }
    </div>

    <div id="til-results" class="til-results" hidden></div>
  </div>
</PageLayout>

<script is:inline define:vars={{ searchIndex }}>
  const input = document.getElementById('til-search');
  const treeEl = document.getElementById('til-tree');
  const resultsEl = document.getElementById('til-results');

  function highlight(text, query) {
    if (!query) return text;
    const escaped = query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    return text.replace(new RegExp(`(${escaped})`, 'gi'), '<mark>$1</mark>');
  }

  function renderResults(q) {
    const norm = q.toLowerCase().trim();

    if (!norm) {
      treeEl.hidden = false;
      resultsEl.hidden = true;
      resultsEl.innerHTML = '';
      return;
    }

    const matched = searchIndex.filter(
      (e) =>
        e.title.toLowerCase().includes(norm) ||
        e.tags.some((t) => t.toLowerCase().includes(norm)) ||
        e.desc.toLowerCase().includes(norm) ||
        e.path.toLowerCase().includes(norm)
    );

    treeEl.hidden = true;
    resultsEl.hidden = false;

    if (matched.length === 0) {
      resultsEl.innerHTML = `<p class="search-empty">No results for "<strong>${q}</strong>"</p>`;
      return;
    }

    resultsEl.innerHTML = matched
      .map(
        (e) => `
      <a class="search-result" href="/til/${e.id}">
        ${e.path ? `<span class="result-path">${e.path}</span>` : ''}
        <span class="result-title">${highlight(e.title, q)}</span>
        ${e.desc ? `<span class="result-desc">${highlight(e.desc, q)}</span>` : ''}
        <span class="result-meta">
          ${e.tags.map((t) => `<span class="result-tag">${t}</span>`).join('')}
          <span class="result-date">${e.date}</span>
        </span>
      </a>
    `
      )
      .join('');
  }

  input.addEventListener('input', (e) => renderResults(e.target.value));
</script>

<style is:global>
  .page-wrap {
    padding: var(--space-12) 0;
  }

  /* ── Search ──────────────────────────────────── */
  .search-wrap {
    margin-bottom: var(--space-10);
    max-width: var(--prose-width);
  }

  .search-input {
    width: 100%;
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    font-family: 'Commit Mono', monospace;
    background: var(--color-surface);
    color: var(--color-text);
    border: 1px solid var(--color-border, rgba(128, 128, 128, 0.25));
    border-radius: var(--radius-sm);
    outline: none;
    transition: border-color 120ms ease;
  }

  .search-input:focus {
    border-color: var(--color-accent);
  }

  .search-input::placeholder {
    color: var(--color-muted);
    opacity: 0.6;
  }

  /* ── Results ─────────────────────────────────── */
  .til-results {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    max-width: var(--prose-width);
  }

  .search-empty {
    color: var(--color-muted);
    font-size: 0.875rem;
  }

  .search-result {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    text-decoration: none !important;
    transition: background 120ms ease;
  }

  .search-result:hover {
    background: var(--color-surface-raised, var(--color-surface));
    outline: 1px solid var(--color-accent);
  }

  .result-path {
    font-size: 0.65rem;
    font-family: 'Commit Mono', monospace;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.7;
  }

  .result-title {
    font-size: 0.9rem;
    color: var(--color-text) !important;
    line-height: 1.4;
  }

  .result-desc {
    font-size: 0.8rem;
    color: var(--color-muted);
    line-height: 1.5;
  }

  .result-meta {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
    align-items: center;
    margin-top: 0.15rem;
  }

  .result-tag {
    font-size: 0.65rem;
    font-family: 'Commit Mono', monospace;
    background: var(--color-mono-faint, rgba(128, 128, 128, 0.12));
    color: var(--color-muted);
    padding: 0.1rem 0.4rem;
    border-radius: var(--radius-sm);
  }

  .result-date {
    font-size: 0.65rem;
    font-family: 'Commit Mono', monospace;
    color: var(--color-muted);
    opacity: 0.6;
    margin-left: auto;
  }

  mark {
    background: transparent;
    color: var(--color-accent);
    font-weight: 600;
  }

  /* ── Tree ────────────────────────────────────── */
  .til-tree {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    max-width: var(--prose-width);
  }

  .til-branch {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .til-cat {
    font-size: 0.65rem !important;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-mono) !important;
    font-family: 'Commit Mono', monospace !important;
    font-weight: 400 !important;
    margin-bottom: var(--space-2);
  }

  .til-subcat-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-mono);
    font-family: 'Commit Mono', monospace;
    font-weight: 400;
  }

  .til-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    padding: 0.2rem 0;
  }

  .til-connector {
    font-family: 'Commit Mono', monospace;
    font-size: 0.75rem;
    color: var(--color-mono);
    opacity: 0.35;
    flex-shrink: 0;
    user-select: none;
    line-height: 1;
  }

  .til-link {
    font-size: 0.9rem;
    color: var(--color-muted) !important;
    text-decoration: none !important;
    line-height: 1.5;
    transition: color 120ms ease;
  }

  .til-link:hover {
    color: var(--color-accent) !important;
  }
</style>
