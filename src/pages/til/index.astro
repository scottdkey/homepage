---
import PageLayout from '../../layouts/PageLayout.astro';
import TilBranch from '../../components/TilBranch.astro';
import type { TilNode } from '../../components/TilBranch.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('til', ({ data }) => !data.draft);

const tree: Record<string, TilNode> = {};
for (const entry of entries) {
  const parts = entry.id.split('/');
  const topCat = parts[0];
  const subPath = parts.slice(1, -1);
  if (!tree[topCat]) tree[topCat] = { entries: [], children: {} };
  let node = tree[topCat];
  for (const seg of subPath) {
    if (!node.children[seg]) node.children[seg] = { entries: [], children: {} };
    node = node.children[seg];
  }
  node.entries.push(entry);
}
const sortedTree = Object.entries(tree).sort(([a], [b]) => a.localeCompare(b));

const searchIndex = entries.map((e) => ({
  id: e.id,
  title: e.data.title,
  tags: e.data.tags,
  desc: e.data.description ?? '',
  date: e.data.pubDate.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
    timeZone: 'UTC',
  }),
  path: e.id.split('/').slice(0, -1).join(' / '),
}));
---

<PageLayout title="TIL">
  <div class="page-wrap">
    <header class="til-header">
      <div class="til-header-left">
        <h1 class="til-title">Today I Learned</h1>
        <span class="til-count">{entries.length} entries</span>
      </div>
      <input
        id="til-search"
        class="search-input"
        type="search"
        placeholder="Search topics, tags…"
        autocomplete="off"
        spellcheck="false"
      />
    </header>

    <div class="til-body">
      <div id="til-results" class="til-results" style="display:none"></div>

      <div id="til-tree" class="til-tree">
        {
          sortedTree.map(([cat, node]) => (
            <div class="til-branch">
              <p class="til-cat">{cat}</p>
              <TilBranch node={node} />
            </div>
          ))
        }
      </div>
    </div>
  </div>
</PageLayout>

<script is:inline define:vars={{ searchIndex }}>
  const input = document.getElementById('til-search');
  const treeEl = document.getElementById('til-tree');
  const resultsEl = document.getElementById('til-results');

  function esc(str) {
    return str.replace(
      /[&<>"']/g,
      (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c]
    );
  }
  function highlight(text, q) {
    if (!q) return esc(text);
    const pattern = q.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    return esc(text).replace(new RegExp(`(${pattern})`, 'gi'), '<mark>$1</mark>');
  }
  function resultCard(e, q) {
    return `<a class="search-result" href="/til/${e.id}">
      ${e.path ? `<span class="result-path">${esc(e.path)}</span>` : ''}
      <span class="result-title">${highlight(e.title, q)}</span>
      ${e.desc ? `<span class="result-desc">${highlight(e.desc, q)}</span>` : ''}
      <span class="result-meta">
        ${e.tags.map((t) => `<span class="result-tag">${esc(t)}</span>`).join('')}
        <span class="result-date">${esc(e.date)}</span>
      </span>
    </a>`;
  }

  function renderResults(q) {
    const norm = q.toLowerCase().trim();

    if (!norm) {
      treeEl.style.display = '';
      resultsEl.style.display = 'none';
      resultsEl.innerHTML = '';
      return;
    }

    const matched = searchIndex.filter(
      (e) =>
        e.title.toLowerCase().includes(norm) ||
        e.tags.some((t) => t.toLowerCase().includes(norm)) ||
        e.desc.toLowerCase().includes(norm) ||
        e.path.toLowerCase().includes(norm)
    );

    treeEl.style.display = 'none';
    resultsEl.style.display = 'flex';

    if (matched.length === 0) {
      resultsEl.innerHTML = `<p class="search-empty">No results for "<strong>${esc(q)}</strong>"</p>`;
      return;
    }

    resultsEl.innerHTML = matched.map((e) => resultCard(e, q)).join('');
  }

  input.addEventListener('input', (e) => renderResults(e.target.value));
</script>

<style is:global>
  .page-wrap {
    padding: var(--space-12) 0 var(--space-16);
  }

  /* ── Header ──────────────────────────────────── */
  .til-header {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    flex-wrap: wrap;
    padding-bottom: var(--space-6);
    border-bottom: 1px solid color-mix(in srgb, var(--color-mono) 15%, transparent);
    margin-bottom: var(--space-8);
  }

  .til-header-left {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    flex: 1;
    min-width: 0;
  }

  .til-title {
    font-size: 1.35rem;
    font-weight: 700;
    white-space: nowrap;
  }

  .til-count {
    font-size: 0.7rem;
    font-family: 'Commit Mono', monospace;
    color: var(--color-mono);
    letter-spacing: 0.06em;
    white-space: nowrap;
  }

  .search-input {
    flex: 1;
    min-width: 180px;
    max-width: 300px;
    margin-left: auto;
    padding: 0.4rem 0.65rem;
    font-size: 0.8rem;
    font-family: 'Commit Mono', monospace;
    background: var(--color-surface);
    color: var(--color-text);
    border: 1px solid color-mix(in srgb, var(--color-mono) 30%, transparent);
    border-radius: var(--radius-sm);
    outline: none;
    transition: border-color 120ms ease;
  }
  .search-input:focus {
    border-color: var(--color-accent);
  }
  .search-input::placeholder {
    color: var(--color-muted);
    opacity: 0.5;
  }

  /* ── Body / Results ──────────────────────────── */
  .til-body {
  }

  .til-results {
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .search-empty {
    color: var(--color-muted);
    font-size: 0.875rem;
    padding: var(--space-4) 0;
  }

  .search-result {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    text-decoration: none !important;
    border: 1px solid transparent;
    transition:
      border-color 120ms ease,
      background 120ms ease;
  }
  .search-result:hover {
    border-color: color-mix(in srgb, var(--color-accent) 50%, transparent);
    background: color-mix(in srgb, var(--color-surface) 80%, var(--color-accent) 20%);
  }

  .result-path {
    font-size: 0.6rem;
    font-family: 'Commit Mono', monospace;
    color: var(--color-mono);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .result-title {
    font-size: 0.875rem;
    color: var(--color-text) !important;
    line-height: 1.4;
  }
  .result-desc {
    font-size: 0.775rem;
    color: var(--color-muted);
    line-height: 1.5;
  }
  .result-meta {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
    align-items: center;
    margin-top: 0.2rem;
  }
  .result-tag {
    font-size: 0.6rem;
    font-family: 'Commit Mono', monospace;
    background: color-mix(in srgb, var(--color-mono) 12%, transparent);
    color: var(--color-muted);
    padding: 0.1rem 0.4rem;
    border-radius: var(--radius-sm);
  }
  .result-date {
    font-size: 0.6rem;
    font-family: 'Commit Mono', monospace;
    color: var(--color-mono);
    margin-left: auto;
  }

  mark {
    background: transparent;
    color: var(--color-accent);
    font-weight: 600;
  }

  /* ── Tree ────────────────────────────────────── */
  .til-tree {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .til-branch {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .til-cat {
    font-size: 0.6rem !important;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-mono) !important;
    font-family: 'Commit Mono', monospace !important;
    font-weight: 400 !important;
    margin-bottom: var(--space-2);
  }

  .til-subcat-label {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-mono);
    font-family: 'Commit Mono', monospace;
    font-weight: 400;
  }

  .til-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    padding: 0.15rem 0;
  }

  .til-connector {
    font-family: 'Commit Mono', monospace;
    font-size: 0.7rem;
    color: var(--color-mono);
    opacity: 0.25;
    flex-shrink: 0;
    user-select: none;
    line-height: 1;
  }

  .til-link {
    font-size: 0.875rem;
    color: var(--color-muted) !important;
    text-decoration: none !important;
    line-height: 1.5;
    transition: color 120ms ease;
  }
  .til-link:hover {
    color: var(--color-accent) !important;
  }
</style>
