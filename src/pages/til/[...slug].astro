---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Tag from '../../components/Tag.astro';
import { getCollection, render } from 'astro:content';

export const prerender = true;

export async function getStaticPaths() {
  const entries = await getCollection('til', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<PageLayout title={entry.data.title} description={entry.data.description} prose={true}>
  <article class="prose page-wrap">
    <PageHero tag="TIL" title={entry.data.title}>
      {
        entry.data.tags.length > 0 && (
          <div class="entry-tags">
            {entry.data.tags.map((t) => (
              <Tag label={t} />
            ))}
          </div>
        )
      }
    </PageHero>
    <Content />
  </article>
</PageLayout>

<style>
  .page-wrap {
    padding: var(--space-12) 0;
  }
  .entry-tags {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
</style>
