---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CaseSection from '../../components/CaseSection.astro';
import Tag from '../../components/Tag.astro';
import { jobs } from '../../data/resume';

export const prerender = true;

export function getStaticPaths() {
  return jobs
    .filter((j) => j.sections.length > 0)
    .map((j) => ({ params: { slug: j.slug }, props: { job: j } }));
}

const { job } = Astro.props;
---

<PageLayout title={job.company} description={`Scott Key at ${job.company} — ${job.intro}`}>
  <article class="page-wrap">
    <PageHero title={job.company}>
      <p class="case-meta mono">{job.title} · {job.dates}</p>
      <p class="case-intro">{job.intro}</p>
      {
        job.stack.length > 0 && (
          <div class="stack-tags">
            {job.stack.map((t) => (
              <Tag label={t} />
            ))}
          </div>
        )
      }
      {
        job.site && (
          <div class="hero-links">
            <a href={job.site} target="_blank" rel="noopener noreferrer" class="hero-link-btn">
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <circle cx="12" cy="12" r="10" />
                <line x1="2" y1="12" x2="22" y2="12" />
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
              </svg>
              {new URL(job.site).hostname}
            </a>
          </div>
        )
      }
    </PageHero>
    {
      job.sections.map((s) => (
        <CaseSection id={s.id} heading={s.heading} paragraphs={s.paragraphs} />
      ))
    }
  </article>
</PageLayout>

<style>
  .page-wrap {
    padding: var(--space-12) 0;
  }
  .case-meta {
    font-size: 0.75rem;
    color: var(--color-mono);
    font-family: 'Commit Mono', monospace;
  }
  .case-intro {
    font-size: 1.05rem;
    color: var(--color-muted);
    line-height: 1.75;
    max-width: var(--prose-width);
  }
  .stack-tags {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
  .hero-links {
    display: flex;
    gap: var(--space-3);
  }
  .hero-link-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-size: 0.75rem;
    font-family: 'Commit Mono', monospace;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--color-muted);
    text-decoration: none;
    padding: var(--space-1) var(--space-3);
    border: 1px solid var(--color-mono);
    border-radius: var(--radius-md);
    transition:
      color 150ms ease,
      border-color 150ms ease;
  }
  .hero-link-btn:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    text-decoration: none;
  }
</style>
