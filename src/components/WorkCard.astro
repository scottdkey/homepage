---
import Tag from './Tag.astro';
interface Props {
  href: string;
  dates: string;
  role: string;
  company: string;
  description: string;
}
const { href, dates, role, company, description } = Astro.props;
---
<a href={href} class="work-card card">
  <div class="card-meta">
    <Tag label={dates} />
    <Tag label={role} />
  </div>
  <h3>{company}</h3>
  <p>{description}</p>
  <span class="card-arrow" aria-hidden="true">→</span>
</a>

<style>
  .work-card {
    text-decoration: none;
    color: var(--color-text);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    background: var(--color-surface);
    border-radius: var(--radius-sm);
    padding: var(--space-6);
    transition: background 150ms ease;
    position: relative;
  }
  .work-card:hover {
    background: color-mix(in srgb, var(--color-surface) 80%, var(--color-accent) 20%);
    text-decoration: none;
  }
  .work-card h3 { font-size: 1.1rem; }
  .work-card p { font-size: 0.875rem; color: var(--color-muted); line-height: 1.6; flex: 1; }
  .card-meta { display: flex; gap: var(--space-2); flex-wrap: wrap; }
  .card-arrow { color: var(--color-accent); font-size: 1rem; align-self: flex-end; }
</style>
