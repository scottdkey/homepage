---
interface Props {
  id: string;
  heading: string;
  paragraphs: string[];
}
const { id, heading, paragraphs } = Astro.props;
---

<section class="case-section" aria-labelledby={`${id}-heading`}>
  <h2 id={`${id}-heading`}>{heading}</h2>
  {paragraphs.map((p) => <p set:html={p} />)}
</section>

<style>
  .case-section {
    max-width: var(--prose-width);
    margin-bottom: var(--space-12);
  }
  .case-section h2 {
    font-size: 1.3rem;
    margin-bottom: var(--space-4);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-surface);
  }
  .case-section p {
    color: var(--color-muted);
    line-height: 1.75;
    margin-bottom: var(--space-4);
  }
</style>
