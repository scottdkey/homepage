---
import ThemeSwitcher from './ThemeSwitcher.astro';
import ReadingModeToggle from './ReadingModeToggle.astro';
import DarkModeToggle from './DarkModeToggle.astro';
import SocialLinks from './SocialLinks.astro';
import { mainNav } from '../data/nav';

const { pathname } = Astro.url;
function isCurrent(href: string) {
  if (href === '/') return pathname === '/';
  return pathname === href || pathname.startsWith(href + '/');
}
---
<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="wordmark" aria-label="Scott Key — home">sk</a>

    <nav aria-label="Main navigation" class="desktop-nav">
      <ul role="list">
        {mainNav.map(link => (
          <li><a href={link.href} aria-current={isCurrent(link.href) ? 'page' : undefined}>{link.label}</a></li>
        ))}
      </ul>
    </nav>

    <div class="header-controls">
      <ReadingModeToggle />
      <div class="mode-group">
        <DarkModeToggle />
        <ThemeSwitcher />
      </div>
      <div class="social-dock" aria-label="Social links">
        <SocialLinks />
      </div>
      <button
        class="contact-trigger"
        aria-haspopup="dialog"
        aria-controls="contact-modal"
        data-contact-trigger
      >
        Get in touch
      </button>
      <button
        class="menu-btn"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-drawer"
        data-menu-btn
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- Mobile drawer -->
<div id="mobile-drawer" class="drawer" aria-hidden="true" data-drawer>
  <div class="drawer-backdrop" data-drawer-backdrop></div>
  <nav class="drawer-panel" aria-label="Mobile navigation">
    <div class="drawer-header">
      <span class="wordmark">sk</span>
      <button class="drawer-close" aria-label="Close menu" data-drawer-close>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <ul role="list" class="drawer-links">
      {mainNav.map(link => (
        <li><a href={link.href} class="drawer-link" aria-current={isCurrent(link.href) ? 'page' : undefined}>{link.label}</a></li>
      ))}
    </ul>
    <button
      class="drawer-contact"
      aria-haspopup="dialog"
      aria-controls="contact-modal"
      data-contact-trigger
      data-drawer-close-on-contact
    >
      Get in touch
    </button>
  </nav>
</div>

<script>
  function initHeader() {
    const menuBtn   = document.querySelector<HTMLButtonElement>('[data-menu-btn]');
    const drawer    = document.querySelector<HTMLElement>('[data-drawer]');
    const closeBtns = document.querySelectorAll<HTMLElement>('[data-drawer-close], [data-drawer-backdrop]');

    function openDrawer() {
      drawer?.setAttribute('aria-hidden', 'false');
      drawer?.classList.add('is-open');
      menuBtn?.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
    function closeDrawer() {
      drawer?.setAttribute('aria-hidden', 'true');
      drawer?.classList.remove('is-open');
      menuBtn?.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    menuBtn?.addEventListener('click', openDrawer);
    closeBtns.forEach(el => el.addEventListener('click', closeDrawer));
    drawer?.querySelectorAll('.drawer-link').forEach(link => link.addEventListener('click', closeDrawer));
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeDrawer(); });

    // Keep --header-height in sync
    const header = document.querySelector<HTMLElement>('.site-header');
    function syncHeight() {
      if (header) document.documentElement.style.setProperty('--header-height', header.getBoundingClientRect().height + 'px');
    }
    syncHeight();
    new ResizeObserver(syncHeight).observe(document.body);

    // Hide on scroll down, reveal on scroll up
    let lastY = 0;
    window.addEventListener('scroll', () => {
      const y = window.scrollY;
      if (y < 80) header?.classList.remove('header-hidden');
      else if (y > lastY) header?.classList.add('header-hidden');
      else header?.classList.remove('header-hidden');
      lastY = y;
    }, { passive: true });
  }

  document.addEventListener('DOMContentLoaded', initHeader);
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-surface);
    border-bottom: 1px solid color-mix(in srgb, var(--color-mono) 15%, transparent);
    padding: var(--space-4) 0;
    transition: transform 280ms ease;
  }
  .site-header.header-hidden { transform: translateY(-110%); }

  .header-inner {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    height: 36px;
  }

  .wordmark {
    font-family: 'Commit Mono', monospace;
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: -0.02em;
    text-decoration: none;
  }

  /* Desktop nav */
  .desktop-nav ul {
    display: flex;
    gap: var(--space-6);
    list-style: none;
  }
  .desktop-nav a {
    font-size: 0.875rem;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 150ms ease;
  }
  .desktop-nav a:hover,
  .desktop-nav a[aria-current="page"] { color: var(--color-text); }

  .header-controls {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-left: auto;
  }

  .mode-group { display: flex; align-items: center; }
  .mode-group :global(.dark-toggle) {
    border-radius: var(--radius-sm) 0 0 var(--radius-sm);
    border-right: none;
  }
  .mode-group :global(.switcher-trigger) {
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }

  .contact-trigger {
    background: var(--color-accent);
    color: var(--color-bg);
    border: none;
    border-radius: var(--radius-sm);
    padding: var(--space-2) var(--space-4);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    cursor: pointer;
    transition: opacity 150ms ease;
  }
  .contact-trigger:hover { opacity: 0.85; }
  .contact-trigger:active { opacity: 0.7; transform: scale(0.97); }

  /* Social dock — normal flow, right-aligned under the button */
  .social-dock {
    display: flex;
    gap: 4px;
    align-items: center;
  }

  /* Social dock tooltips point downward */
  .social-dock :global([data-tooltip]::after) {
    bottom: auto;
    top: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%);
  }

  /* Hamburger — hidden on desktop */
  .menu-btn {
    display: none;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    background: transparent;
    border: 1px solid var(--color-muted);
    border-radius: var(--radius-sm);
    color: var(--color-muted);
    cursor: pointer;
    transition: color 150ms ease, border-color 150ms ease;
  }
  .menu-btn:hover {
    color: var(--color-text);
    border-color: var(--color-accent);
  }
  .menu-btn:active { transform: scale(0.93); }

  /* Header tooltips appear below */
  .site-header :global([data-tooltip]::after) {
    bottom: auto;
    top: calc(100% + 6px);
    transform: translateX(-50%);
  }

  @media (max-width: 900px) {
    .desktop-nav { display: none; }
    .header-inner { gap: var(--space-4); }
    .menu-btn { display: flex; }
    .contact-trigger { display: none; }
  }

  @media (max-width: 640px) {
    .header-controls { gap: var(--space-2); }
  }

  /* ── Drawer ─────────────────────────────────────────── */
  .drawer {
    position: fixed;
    inset: 0;
    z-index: 200;
    pointer-events: none;
  }
  .drawer.is-open { pointer-events: all; }

  .drawer-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    opacity: 0;
    transition: opacity 250ms ease;
    cursor: pointer;
  }
  .drawer.is-open .drawer-backdrop { opacity: 1; }

  .drawer-panel {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(320px, 85vw);
    background: var(--color-bg);
    border-left: 1px solid var(--color-surface);
    display: flex;
    flex-direction: column;
    padding: var(--space-6);
    gap: var(--space-6);
    transform: translateX(100%);
    transition: transform 250ms ease;
  }
  .drawer.is-open .drawer-panel { transform: translateX(0); }

  .drawer-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .drawer-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    background: transparent;
    border: 1px solid var(--color-muted);
    border-radius: var(--radius-sm);
    color: var(--color-muted);
    cursor: pointer;
    transition: color 150ms ease, border-color 150ms ease;
  }
  .drawer-close:hover {
    color: var(--color-text);
    border-color: var(--color-accent);
  }

  .drawer-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
    flex: 1;
  }

  .drawer-link {
    display: block;
    padding: var(--space-4) 0;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-muted);
    text-decoration: none;
    border-bottom: 1px solid var(--color-surface);
    transition: color 150ms ease;
  }
  .drawer-link:hover { color: var(--color-accent); text-decoration: none; }
  .drawer-link[aria-current="page"] {
    color: var(--color-accent);
  }

  .drawer-contact {
    background: var(--color-accent);
    color: var(--color-bg);
    border: none;
    border-radius: var(--radius-sm);
    padding: var(--space-3) var(--space-6);
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 150ms ease;
    width: 100%;
  }
  .drawer-contact:hover { opacity: 0.85; }

</style>
