---
const themes = [
  { id: 'tide', label: 'Slate & Tide', color: '#3ABBA4' },
  { id: 'forest', label: 'Forest Floor', color: '#4DB885' },
  { id: 'copper', label: 'Copper & Clay', color: '#D4884A' },
  { id: 'ocean', label: 'Deep Ocean', color: '#5B9CF6' },
];
---

<div class="theme-switcher" data-theme-switcher>
  <button
    class="switcher-trigger"
    aria-expanded="false"
    aria-haspopup="listbox"
    aria-label="Change color theme"
    data-tooltip="Color theme"
    data-theme-chevron
  >
    <svg
      width="12"
      height="12"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <polyline points="9 18 15 12 9 6"></polyline>
    </svg>
  </button>

  <div class="theme-dropdown" role="listbox" aria-label="Color theme" data-theme-dropdown hidden>
    {
      themes.map((t) => (
        <button
          class="theme-option"
          role="option"
          data-theme-id={t.id}
          aria-selected="false"
          style={`--swatch: ${t.color}`}
        >
          <span class="swatch" aria-hidden="true" />
          <span>{t.label}</span>
        </button>
      ))
    }
  </div>
</div>

<script>
  function initThemeSwitcher() {
    const switcher = document.querySelector<HTMLElement>('[data-theme-switcher]');
    const trigger = document.querySelector<HTMLButtonElement>('[data-theme-chevron]');
    const dropdown = document.querySelector<HTMLElement>('[data-theme-dropdown]');
    const options = document.querySelectorAll<HTMLButtonElement>('[data-theme-id]');
    if (!trigger || !dropdown) return;

    function setTheme(id: string) {
      document.documentElement.setAttribute('data-theme', id);
      localStorage.setItem('theme', id);
      options.forEach((o) => o.setAttribute('aria-selected', String(o.dataset.themeId === id)));
    }
    function setOpen(open: boolean) {
      trigger!.setAttribute('aria-expanded', String(open));
      if (open) dropdown!.removeAttribute('hidden');
      else dropdown!.setAttribute('hidden', '');
    }

    setTheme(localStorage.getItem('theme') || 'tide');

    trigger.addEventListener('click', () =>
      setOpen(trigger.getAttribute('aria-expanded') !== 'true')
    );
    options.forEach((btn) =>
      btn.addEventListener('click', () => {
        setTheme(btn.dataset.themeId!);
        setOpen(false);
      })
    );
    document.addEventListener('click', (e) => {
      if (!switcher?.contains(e.target as Node)) setOpen(false);
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') setOpen(false);
    });
  }

  document.addEventListener('DOMContentLoaded', initThemeSwitcher);
</script>

<style>
  .theme-switcher {
    position: relative;
  }

  .switcher-trigger {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    background: transparent;
    border: 1px solid var(--color-muted);
    border-radius: var(--radius-sm);
    color: var(--color-muted);
    cursor: pointer;
    transition:
      color 150ms ease,
      border-color 150ms ease;
  }
  .switcher-trigger:hover,
  .switcher-trigger[aria-expanded='true'] {
    color: var(--color-text);
    border-color: var(--color-accent);
  }
  .switcher-trigger:active {
    transform: scale(0.93);
  }

  /* Dropdown panel */
  .theme-dropdown {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    background: var(--color-surface);
    border: 1px solid var(--color-mono);
    border-radius: var(--radius-sm);
    overflow: hidden;
    min-width: 160px;
    z-index: 200;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
  }

  .theme-option {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    width: 100%;
    background: none;
    border: none;
    padding: var(--space-3) var(--space-4);
    cursor: pointer;
    color: var(--color-muted);
    font-size: 0.8rem;
    letter-spacing: 0.02em;
    text-align: left;
    transition:
      background 120ms ease,
      color 120ms ease;
  }
  .theme-option:hover {
    background: color-mix(in srgb, var(--color-surface) 60%, var(--color-accent) 40%);
    color: var(--color-text);
  }
  .theme-option[aria-selected='true'] {
    color: var(--color-text);
  }
  .theme-option[aria-selected='true'] .swatch {
    outline: 2px solid var(--color-text);
    outline-offset: 2px;
  }

  .swatch {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--swatch);
    flex-shrink: 0;
  }
</style>
