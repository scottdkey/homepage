---
import Tag from './Tag.astro';
interface Props {
  name: string;
  description: string;
  tags: string[];
  site?: string;
  github?: string;
}
const { name, description, tags, site, github } = Astro.props;
---
<div class="project-card">
  <div class="card-body">
    <h3>{name}</h3>
    <p>{description}</p>
  </div>
  <div class="card-footer">
    <div class="card-tags">
      {tags.map(t => <Tag label={t} />)}
    </div>
    {(site || github) && (
      <div class="card-links">
        {site && (
          <a href={site} target="_blank" rel="noopener noreferrer" class="card-link" aria-label={`${name} — live site`}>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <line x1="2" y1="12" x2="22" y2="12"/>
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
            </svg>
            Site
          </a>
        )}
        {github && (
          <a href={github} target="_blank" rel="noopener noreferrer" class="card-link" aria-label={`${name} — GitHub`}>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.342-3.369-1.342-.454-1.155-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
            </svg>
            GitHub
          </a>
        )}
      </div>
    )}
  </div>
</div>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    background: var(--color-surface);
    border-radius: var(--radius-sm);
    padding: var(--space-6);
    border: 1px solid transparent;
    transition: border-color 150ms ease;
  }

.card-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex: 1;
  }

  .project-card h3 { font-size: 0.95rem; font-weight: 700; }
  .project-card p { font-size: 0.825rem; color: var(--color-muted); line-height: 1.6; }

  .card-footer {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-top: auto;
  }

  .card-tags {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
    position: relative;
    z-index: 1;
  }

  .card-links {
    display: flex;
    gap: var(--space-3);
    padding-top: var(--space-3);
    border-top: 1px solid color-mix(in srgb, var(--color-mono) 30%, transparent);
    position: relative;
    z-index: 1;
  }

  .card-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-size: 0.75rem;
    font-family: 'Commit Mono', monospace;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--color-muted);
    text-decoration: none;
    padding: var(--space-1) var(--space-3);
    border: 1px solid var(--color-mono);
    border-radius: var(--radius-md);
    transition: color 150ms ease, border-color 150ms ease;
  }
  .card-link:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    text-decoration: none;
  }
</style>
