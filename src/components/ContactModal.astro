---
---
<div
  id="contact-modal"
  role="dialog"
  aria-modal="true"
  aria-labelledby="contact-modal-title"
  aria-hidden="true"
  class="modal-backdrop"
>
  <div class="modal-panel">
    <div class="modal-header">
      <h2 id="contact-modal-title">Get in touch</h2>
      <button class="modal-close" aria-label="Close contact form" data-contact-close>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <form class="contact-form" id="contact-form" novalidate>
      <div class="field">
        <label for="contact-name">Name</label>
        <input id="contact-name" name="name" type="text" autocomplete="name" required />
      </div>
      <div class="field">
        <label for="contact-email">Email</label>
        <input id="contact-email" name="email" type="email" autocomplete="email" required />
      </div>
      <div class="field">
        <label for="contact-message">Message</label>
        <textarea id="contact-message" name="message" rows="5" required></textarea>
      </div>
      <button type="submit" class="submit-btn" data-submit-btn>Send message</button>
    </form>

    <div class="form-success" id="form-success" hidden>
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/><polyline points="9 12 11 14 15 10"/>
      </svg>
      <p>Message sent. I'll get back to you soon.</p>
    </div>

    <p class="form-error" id="form-error" hidden>Something went wrong — try emailing me directly.</p>
  </div>
</div>

<script>
  function initModal() {
    const modal     = document.getElementById('contact-modal');
    const form      = document.getElementById('contact-form') as HTMLFormElement | null;
    const submitBtn = document.querySelector<HTMLButtonElement>('[data-submit-btn]');
    const success   = document.getElementById('form-success');
    const errorMsg  = document.getElementById('form-error');
    const triggers  = document.querySelectorAll('[data-contact-trigger]');
    const closeBtn  = document.querySelector('[data-contact-close]');
    if (!modal || !form || !success || !errorMsg) return;

    function openModal() {
      form!.hidden        = false;
      form!.reset();
      success!.hidden     = true;
      errorMsg!.hidden    = true;
      if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Send message'; }
      modal!.setAttribute('aria-hidden', 'false');
      modal!.classList.add('is-open');
      modal!.querySelector<HTMLElement>('input, textarea')?.focus();
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      modal!.classList.remove('is-open');
      setTimeout(() => {
        modal!.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      }, 200);
    }

    triggers.forEach(t => t.addEventListener('click', openModal));
    closeBtn?.addEventListener('click', closeModal);
    modal.addEventListener('click', e => { if (e.target === modal) closeModal(); });
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape' && modal!.classList.contains('is-open')) closeModal();
    });

    modal.addEventListener('keydown', e => {
      if (e.key !== 'Tab') return;
      const focusable = modal!.querySelectorAll<HTMLElement>(
        'button:not([hidden]), input:not([hidden]), textarea:not([hidden]), [tabindex]:not([tabindex="-1"])'
      );
      const first = focusable[0];
      const last  = focusable[focusable.length - 1];
      if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
      else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
    });

    form.addEventListener('submit', async e => {
      e.preventDefault();
      if (!submitBtn) return;
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending…';
      errorMsg!.hidden = true;
      try {
        const res = await fetch('/api/contact', { method: 'POST', body: new FormData(form!) });
        if (res.ok) { form!.hidden = true; success!.hidden = false; }
        else throw new Error('non-ok');
      } catch {
        errorMsg!.hidden = false;
        submitBtn.disabled = false;
        submitBtn.textContent = 'Send message';
      }
    });
  }

  document.addEventListener('DOMContentLoaded', initModal);
</script>

<style>
  .modal-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0);
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-4);
    visibility: hidden;
    opacity: 0;
    transition: opacity 200ms ease, background 200ms ease, visibility 0ms linear 200ms;
  }
  .modal-backdrop.is-open {
    visibility: visible;
    opacity: 1;
    background: rgba(0, 0, 0, 0.6);
    transition: opacity 200ms ease, background 200ms ease;
  }

  .modal-panel {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    width: 100%;
    max-width: 480px;
    position: relative;
    opacity: 0;
    transform: scale(0.95) translateY(-12px);
    transition: opacity 250ms ease, transform 250ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .modal-backdrop.is-open .modal-panel {
    opacity: 1;
    transform: scale(1) translateY(0);
  }

  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-6);
  }
  .modal-header h2 { font-size: 1.25rem; }

  .modal-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    background: none;
    border: 1px solid var(--color-mono);
    border-radius: var(--radius-sm);
    color: var(--color-muted);
    cursor: pointer;
    transition: color 150ms ease, border-color 150ms ease;
  }
  .modal-close:hover { color: var(--color-text); border-color: var(--color-accent); }

  .field {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }
  label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-family: 'Commit Mono', monospace;
  }
  input, textarea {
    background: var(--color-bg);
    border: 1px solid var(--color-mono);
    border-radius: var(--radius-sm);
    color: var(--color-text);
    font-family: inherit;
    font-size: 0.9rem;
    padding: var(--space-3);
    width: 100%;
    transition: border-color 120ms ease;
  }
  input:focus, textarea:focus { border-color: var(--color-accent); outline: none; }
  textarea { resize: vertical; }

  .submit-btn {
    background: var(--color-accent);
    color: var(--color-bg);
    border: none;
    border-radius: var(--radius-sm);
    padding: var(--space-3) var(--space-6);
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    width: 100%;
    margin-top: var(--space-2);
    transition: opacity 150ms ease;
  }
  .submit-btn:hover:not(:disabled) { opacity: 0.85; }
  .submit-btn:disabled { opacity: 0.5; cursor: not-allowed; }

  .form-success {
    display: none;
  }
  .form-success:not([hidden]) {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-8) 0;
    text-align: center;
    color: var(--color-accent);
  }
  .form-success p { color: var(--color-text); font-size: 0.95rem; }

  .form-error {
    display: none;
  }
  .form-error:not([hidden]) {
    display: block;
    color: #e05252;
    font-size: 0.85rem;
    margin-top: var(--space-3);
    text-align: center;
  }
</style>
