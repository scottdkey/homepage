---
import type { CollectionEntry } from 'astro:content';

export interface TilNode {
  entries: CollectionEntry<'til'>[];
  children: Record<string, TilNode>;
}

interface Props {
  node: TilNode;
  depth?: number;
}

const { node, depth = 0 } = Astro.props;

const entries = node.entries;
const childCategories = Object.entries(node.children).sort(([a], [b]) => a.localeCompare(b));
const totalItems = entries.length + childCategories.length;
const pad = depth > 0 ? `padding-left: calc(${depth} * 1.25rem)` : '';
---

{
  entries.map((entry, i) => {
    const isLast = i === entries.length - 1 && childCategories.length === 0;
    return (
      <div class="til-row" style={pad}>
        <span class="til-connector" aria-hidden="true">
          {isLast ? '└' : '├'}
        </span>
        <a class="til-link" href={`/til/${entry.id}`}>
          {entry.data.title}
        </a>
      </div>
    );
  })
}

{
  childCategories.map(([key, childNode], i) => {
    const isLast = entries.length + i === totalItems - 1;
    return (
      <div>
        <div class="til-row" style={pad}>
          <span class="til-connector" aria-hidden="true">
            {isLast ? '└' : '├'}
          </span>
          <span class="til-subcat-label">{key}</span>
        </div>
        <Astro.self node={childNode} depth={depth + 1} />
      </div>
    );
  })
}
