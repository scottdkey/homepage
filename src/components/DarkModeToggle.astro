---
---
<button
  class="dark-toggle"
  aria-pressed="false"
  aria-label="Switch to light mode"
  data-tooltip="Switch to light mode"
  data-dark-toggle
>
  <svg class="icon moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </svg>
  <svg class="icon sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="5"/>
    <line x1="12" y1="1" x2="12" y2="3"/>
    <line x1="12" y1="21" x2="12" y2="23"/>
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
    <line x1="1" y1="12" x2="3" y2="12"/>
    <line x1="21" y1="12" x2="23" y2="12"/>
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
  </svg>
</button>

<script>
  function initDarkToggle() {
    const btn = document.querySelector<HTMLButtonElement>('[data-dark-toggle]');
    if (!btn) return;

    function applyMode(light: boolean) {
      document.documentElement.setAttribute('data-mode', light ? 'light' : 'dark');
      btn!.setAttribute('aria-pressed', String(light));
      btn!.classList.toggle('is-light', light);
      const label = light ? 'Switch to dark mode' : 'Switch to light mode';
      btn!.setAttribute('aria-label', label);
      btn!.setAttribute('data-tooltip', label);
    }

    applyMode(localStorage.getItem('colorMode') === 'light');

    btn.addEventListener('click', () => {
      const next = btn.getAttribute('aria-pressed') !== 'true';
      applyMode(next);
      localStorage.setItem('colorMode', next ? 'light' : 'dark');
    });
    btn.addEventListener('mouseenter', () => {
      const label = btn.classList.contains('is-light') ? 'Switch to dark mode' : 'Switch to light mode';
      btn.setAttribute('data-tooltip', label);
    });
  }

  document.addEventListener('DOMContentLoaded', initDarkToggle);
</script>

<style>
  .dark-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    background: transparent;
    border: 1px solid var(--color-muted);
    border-radius: var(--radius-sm);
    color: var(--color-muted);
    cursor: pointer;
    position: relative;
    transition: color 150ms ease, border-color 150ms ease;
  }
  .dark-toggle:hover,
  .dark-toggle[aria-pressed="true"] {
    color: var(--color-text);
    border-color: var(--color-accent);
  }
  .dark-toggle:active { transform: scale(0.93); }

  .icon {
    position: absolute;
    transition: opacity 200ms ease, transform 200ms ease;
  }

  .moon { opacity: 1; transform: rotate(0deg) scale(1); }
  .sun  { opacity: 0; transform: rotate(90deg) scale(0.6); }

  .dark-toggle.is-light .moon { opacity: 0; transform: rotate(-90deg) scale(0.6); }
  .dark-toggle.is-light .sun  { opacity: 1; transform: rotate(0deg) scale(1); }
</style>
