---
import EmailLink from './EmailLink.astro';
import { resumeSocialLinks } from '../data/resume';

interface Props {
  tooltip?: boolean;
}
const { tooltip = true } = Astro.props;

const iconLinks = [resumeSocialLinks.github, resumeSocialLinks.linkedin];
---

{
  iconLinks.map((link) => (
    <a
      href={link.href}
      rel="noopener noreferrer"
      target="_blank"
      aria-label={link.ariaLabel}
      class="icon-link"
      data-tooltip={tooltip ? link.ariaLabel : undefined}
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d={link.svgPath} />
      </svg>
    </a>
  ))
}
<EmailLink class="icon-link" icon={true} data-tooltip={tooltip ? 'Email' : undefined} />

<style>
  /* :global so the rule reaches EmailLink's rendered <a> */
  :global(.icon-link) {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    color: var(--color-mono);
    text-decoration: none;
    transition: color 150ms ease;
  }
  :global(.icon-link:hover) {
    color: var(--color-accent);
  }
</style>
