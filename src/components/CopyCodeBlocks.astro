<style is:global>
  pre {
    position: relative;
    cursor: pointer;
  }

  pre.copy-flash {
    outline: 1px solid var(--color-accent);
    transition: outline 150ms ease;
  }

  .copy-hint {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    background: rgba(0, 0, 0, 0.18);
    color: rgba(255, 255, 255, 0.35);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-sm);
    padding: 0.2rem 0.6rem;
    font-size: 0.6rem;
    font-family: 'Commit Mono', monospace;
    letter-spacing: 0.05em;
    pointer-events: none;
    opacity: 0;
    transition: opacity 120ms ease, color 120ms ease, border-color 120ms ease;
    line-height: 1.6;
    user-select: none;
  }

  pre:hover .copy-hint {
    opacity: 1;
  }

  pre.copy-flash .copy-hint {
    opacity: 1;
    color: rgba(255, 255, 255, 0.9);
    border-color: rgba(255, 255, 255, 0.4);
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('pre').forEach(pre => {
    const hint = document.createElement('span');
    hint.className = 'copy-hint';
    hint.textContent = 'copy';
    hint.setAttribute('aria-hidden', 'true');
    pre.appendChild(hint);

    pre.addEventListener('click', async () => {
      const selection = window.getSelection();
      if (selection && selection.toString().length > 0) return;

      const codeEl = pre.querySelector<HTMLElement>('code');
      const code = (codeEl ?? pre).innerText;
      await navigator.clipboard.writeText(code.replace(/\ncopy$/, '').trimEnd());

      hint.textContent = 'copied!';
      pre.classList.add('copy-flash');
      setTimeout(() => {
        hint.textContent = 'copy';
        pre.classList.remove('copy-flash');
      }, 1500);
    });
  });
</script>
